{
  "name": "burrow",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "bun packages/tcp-server/server.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "net": "^1.0.2"
  }
}
